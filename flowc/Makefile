# Makefile
#
# Build rules for flowc. Conformant POSIX make: the `.POSIX:` target on
# the first non-comment line engages strict POSIX semantics in BSD make
# and gmake. Run ./configure first; it generates config.mk. The
# Makefile does NOT invoke configure — that is a manual step performed
# once after checkout and again whenever the build environment changes
# (a discipline borrowed from autoconf/automake without the autotools).
#
# Artifacts produced:
#
#   libflowc.a   The compiler as a library. Install target ships this
#                plus src/api.h for hosts that want to drive the
#                pipeline in-process.
#   flowc        The CLI binary. Links statically against libflowc.a.
#
# To rebuild the project from a clean checkout:
#
#     ./configure
#     make
#
# To run the test suite:
#
#     make test
#
# To install libflowc.a + api.h to PREFIX (default /usr/local):
#
#     make install PREFIX=/usr/local
#
# To remove all build artifacts:
#
#     make clean

.POSIX:

include config.mk

PREFIX = /usr/local

# ---------------------------------------------------------------------
# Flags
#
# CONFIG_* are populated by configure; we copy them into the standard
# names ($(CFLAGS) etc.) so that the user can override on the command
# line with `make CFLAGS=-O2` in the usual POSIX manner.
#
# GEN_CFLAGS is the relaxed flag set used only when compiling the C
# files generated by flex and bison. That code is not ours, routinely
# trips -Wpedantic and -Werror, and isolating its build flags avoids
# our having to disable warnings globally.
# ---------------------------------------------------------------------

CFLAGS   = $(CONFIG_CFLAGS)
CPPFLAGS = $(CONFIG_CPPFLAGS)
LDFLAGS  = $(CONFIG_LDFLAGS)
LDLIBS   = $(CONFIG_LDLIBS)

AR       = ar
ARFLAGS  = rcs

INSTALL  = install


# ---------------------------------------------------------------------
# Object lists
#
# LIB_OBJS is everything that goes into libflowc.a — every compiler
# pass plus the api layer. main.o is the CLI driver and is NOT in the
# library; it links against libflowc.a to produce the flowc binary.
#
# Listed in roughly dependency order. The link command does not
# require this ordering — these are object files, not libraries —
# but a stable order makes the build log easier to read.
# ---------------------------------------------------------------------

LIB_OBJS = src/api.o \
           src/util.o \
           src/ast.o \
           src/ast_dump.o \
           src/resolve.o \
           src/check.o \
           src/ir.o \
           src/parse.tab.o \
           src/lex.yy.o

CLI_OBJS = src/main.o


# ---------------------------------------------------------------------
# Top-level targets
#
# `all` is the default because it is the first target in the file
# (POSIX make's rule for selecting a default target). It depends on
# `flowc` and `libflowc.a` so `make` builds both.
# ---------------------------------------------------------------------

all: flowc libflowc.a

libflowc.a: $(LIB_OBJS)
	$(AR) $(ARFLAGS) $@ $(LIB_OBJS)

flowc: $(CLI_OBJS) libflowc.a
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $(CLI_OBJS) libflowc.a $(LDLIBS)


# ---------------------------------------------------------------------
# Generated sources
#
# `bison -d` writes both parse.tab.c and parse.tab.h. Listing both
# files as targets of the same recipe tells make they are co-produced
# by a single invocation; without this, a parallel build (`make -j`)
# can race and run bison twice.
#
# We commit src/parse.y and src/lex.l; we do NOT commit the generated
# .tab.c / .tab.h / .yy.c. They are rebuilt on every fresh checkout.
# ---------------------------------------------------------------------

src/parse.tab.c src/parse.tab.h: src/parse.y
	$(YACC) -d -o src/parse.tab.c src/parse.y

src/lex.yy.c: src/lex.l src/parse.tab.h
	$(LEX) -o $@ src/lex.l


# ---------------------------------------------------------------------
# Object rules
#
# Written explicitly rather than via POSIX suffix rules because suffix
# rules are specified only for files in the current directory, and we
# keep all sources under src/. Explicit rules also serve as the
# canonical record of each translation unit's local header
# dependencies, which is what drives correct incremental rebuilds.
# ---------------------------------------------------------------------

src/main.o: src/main.c src/api.h src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ src/main.c

src/api.o: src/api.c src/api.h src/util.h src/lex.h src/parse.h src/parse.tab.h src/ast.h src/ast_dump.h src/resolve.h src/check.h src/ir.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ src/api.c

src/util.o: src/util.c src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ src/util.c

src/ast.o: src/ast.c src/ast.h src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ src/ast.c

src/ast_dump.o: src/ast_dump.c src/ast_dump.h src/ast.h src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ src/ast_dump.c

src/resolve.o: src/resolve.c src/resolve.h src/ast.h src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ src/resolve.c

src/check.o: src/check.c src/check.h src/resolve.h src/ast.h src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ src/check.c

src/ir.o: src/ir.c src/ir.h src/ast.h src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) -c -o $@ src/ir.c

src/parse.tab.o: src/parse.tab.c src/parse.tab.h src/util.h
	$(CC) $(GEN_CFLAGS) $(CPPFLAGS) -c -o $@ src/parse.tab.c

src/lex.yy.o: src/lex.yy.c src/parse.tab.h src/util.h src/lex.h
	$(CC) $(GEN_CFLAGS) $(CPPFLAGS) -c -o $@ src/lex.yy.c


# ---------------------------------------------------------------------
# Tests
#
# Two test surfaces:
#
#   1. tests/run.sh — POSIX sh driver that runs the flowc binary over
#      .flow fixtures in tests/fixtures/ and diffs against the
#      sidecar expected.{out,err,exit} files. The PASS/FAIL summary
#      line comes from here.
#
#   2. tests/api/* — small C binaries that link directly against
#      libflowc.a and exercise the public C API. Each is a one-shot
#      assertion: exit 0 on success, non-zero on failure. The
#      Makefile chains them after run.sh; if any assertion fails,
#      `make test` fails.
# ---------------------------------------------------------------------

API_TESTS = tests/api/test_buffer_vs_file \
            tests/api/test_reset_cycle \
            tests/api/test_recompile_after_error

tests/api/test_buffer_vs_file: tests/api/test_buffer_vs_file.c libflowc.a src/api.h src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) \
	      -o $@ tests/api/test_buffer_vs_file.c libflowc.a $(LDLIBS)

tests/api/test_reset_cycle: tests/api/test_reset_cycle.c libflowc.a src/api.h src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) \
	      -o $@ tests/api/test_reset_cycle.c libflowc.a $(LDLIBS)

tests/api/test_recompile_after_error: tests/api/test_recompile_after_error.c libflowc.a src/api.h src/util.h
	$(CC) $(CFLAGS) $(CPPFLAGS) $(LDFLAGS) \
	      -o $@ tests/api/test_recompile_after_error.c libflowc.a $(LDLIBS)

test: flowc $(API_TESTS)
	./tests/run.sh
	./tests/api/test_buffer_vs_file
	./tests/api/test_reset_cycle
	./tests/api/test_recompile_after_error


# ---------------------------------------------------------------------
# Install
#
# Ships libflowc.a + the single public header. parse.tab.h, util.h,
# lex.h, parse.h, ast.h, etc. are internal — they are required to
# build libflowc.a but are not part of the public ABI. util.h is the
# one exception: it carries the Diagnostic / DiagStream / SrcLoc
# types that api.h re-exports, so we install it alongside api.h.
# ---------------------------------------------------------------------

install: libflowc.a
	$(INSTALL) -d $(DESTDIR)$(PREFIX)/lib
	$(INSTALL) -d $(DESTDIR)$(PREFIX)/include/flowc
	$(INSTALL) -m 644 libflowc.a $(DESTDIR)$(PREFIX)/lib/libflowc.a
	$(INSTALL) -m 644 src/api.h  $(DESTDIR)$(PREFIX)/include/flowc/api.h
	$(INSTALL) -m 644 src/util.h $(DESTDIR)$(PREFIX)/include/flowc/util.h


# ---------------------------------------------------------------------
# Housekeeping
#
# `clean` removes the binary, the library archive, all object files,
# and the generated flex/bison sources. It does not remove config.mk;
# that is the product of ./configure and persists across `make clean`.
# Running ./configure again is the way to regenerate config.mk.
# ---------------------------------------------------------------------

clean:
	rm -f flowc libflowc.a \
	      src/main.o src/api.o src/util.o src/ast.o src/ast_dump.o \
	      src/resolve.o src/check.o src/ir.o \
	      src/lex.yy.o src/parse.tab.o \
	      src/lex.yy.c src/parse.tab.c src/parse.tab.h \
	      tests/api/test_buffer_vs_file tests/api/test_reset_cycle
